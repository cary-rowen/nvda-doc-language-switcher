{
  "manifest_version": 3,
  "name": "NVDA Documentation Language Switcher",
  "version": "1.2.0",
  "description": "Adds English and local-language switch links to NVDA documentation pages.",
  "homepage_url": "https://github.com/cary-rowen/nvda-doc-language-switcher",
  "minimum_chrome_version": "88",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://download.nvaccess.org/documentation/*.html",
        "https://download.nvaccess.org/documentation/*/*.html",
        "https://download.nvaccess.org/releases/*/documentation/*.html",
        "https://download.nvaccess.org/releases/*/documentation/*/*.html",
        "https://download.nvaccess.mirror.nvdadr.com/documentation/*.html",
        "https://download.nvaccess.mirror.nvdadr.com/documentation/*/*.html",
        "https://www.nvaccess.org/files/nvda/documentation/*.html",
        "https://www.nvaccess.org/files/nvda/documentation/*",
        "file:///*/NVDA/documentation/*.html",
        "file:///*/NVDA/documentation/*/*.html"
      ],
      "js": [
        "nvda-doc-language-switcher.js"
      ],
      "run_at": "document_end"
    }
  ]
}
